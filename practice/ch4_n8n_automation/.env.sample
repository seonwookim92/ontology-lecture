# 데이터셋 설정
# Choose a dataset among the following;
# stackoverflow / pole / network-management / recommendations
# (비워두기)      : Neo4j를 빈 상태로 시작 (커스텀 KG 구성용)
ACTIVE_DATASET=

# Neo4j 설정
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=SuperSecretPassword

# vLLM 서버 설정 (실제 서버 IP로 수정 필요)
# n8n Credential에서 직접 설정: Name=OpenAI account, API Key=EMPTY, Base URL 아래 참고
LLM_MODEL=qwen3.6-35b
VLLM_BASE_URL=http://10.10.10.10:8081/v1
LLM_API_KEY=EMPTY
