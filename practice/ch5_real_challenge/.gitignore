# ─── 다운로드 원본 (대용량) ───────────────────────────────────────────────────
data/**/_raw*

# ─── 전처리된 데이터 (bash scripts/fetch_all.sh 로 재생성) ────────────────────
data/**/*.json

# 디렉토리 구조 유지용 마커는 추적 유지
!data/**/.gitkeep

# ─── 기타 ──────────────────────────────────────────────────────────────────────
.DS_Store
*.pyc
__pycache__/
